LOCAL_DATA_DIR=./runs/local
MONGODB_URI=sqlite:///./runs/local/agent.db
MONGODB_DB=personal_browser_agent
ALLOW_MEMORY_FALLBACK=true
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001
MODEL_OUTPUT_DIR=./runs/user-models
COMPUTER_DATASET_DIR=./runs/computer-use-datasets
COMPUTER_MODEL_PROVIDER=opencua
OPENCUA_BASE_URL=http://127.0.0.1:8001/v1
OPENCUA_MODEL=opencua-7b
OPENCUA_TIMEOUT_SECONDS=45
OPENCUA_AUTOSTART=1
OPENCUA_PERSISTENT=1
OPENCUA_CONDA_ENV=opencua
# Optional. Use this if vllm is inside conda or another environment.
# OPENCUA_START_COMMAND=VLLM_CPU_KVCACHE_SPACE=4 /Users/vincentqi/miniconda3/envs/opencua/bin/vllm serve xlangai/OpenCUA-7B --trust-remote-code --served-model-name opencua-7b --host 127.0.0.1 --port 8001 --max-model-len 4096
BACKEND_INTERNAL_URL=http://127.0.0.1:8000
NEXT_PUBLIC_API_URL=
CLOD_API_KEY=
CLOD_MODEL=DeepSeek V3
CLOD_BASE_URL=https://api.clod.io/v1
CLOD_TIMEOUT_SECONDS=30
CLOD_MAX_COMPLETION_TOKENS=1024
